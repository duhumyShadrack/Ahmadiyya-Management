'use client';

import { useEffect, useState } from 'react';
import { createClient } from '@/utils/supabase/client';
import { toast } from 'sonner';
import {
  BarChart,
  Bar,
  XAxis,
  YAxis,
  Tooltip,
  ResponsiveContainer,
  PieChart,
  Pie,
  Cell,
  Legend,
} from 'recharts';

// ... inside CollectionsDashboard component, after stats grid

const successData = [
  { name: 'Success Rate', value: stats.successRate, fill: '#10b981' },
  { name: 'Failure Rate', value: 100 - stats.successRate, fill: '#ef4444' },
];

const channelData = [
  { name: 'WhatsApp', value: collectionLogs.filter(l => l.channel === 'whatsapp').length, fill: '#22c55e' },
  { name: 'Email', value: collectionLogs.filter(l => l.channel === 'email').length, fill: '#3b82f6' },
  { name: 'Voice', value: collectionLogs.filter(l => l.channel === 'voice').length, fill: '#a855f7' },
  { name: 'Human', value: collectionLogs.filter(l => l.channel === 'human').length, fill: '#eab308' },
];

return (
  // ... existing JSX

  {/* Charts */}
  <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
    {/* Success Rate Pie Chart */}
    <div className="bg-white p-6 rounded-xl shadow-md border">
      <h3 className="text-lg font-semibold mb-4">Collection Success Rate</h3>
      <ResponsiveContainer width="100%" height={250}>
        <PieChart>
          <Pie
            data={successData}
            innerRadius={60}
            outerRadius={80}
            paddingAngle={5}
            dataKey="value"
          >
            {successData.map((entry, index) => (
              <Cell key={`cell-${index}`} fill={entry.fill} />
            ))}
          </Pie>
          <Tooltip />
          <Legend />
        </PieChart>
      </ResponsiveContainer>
    </div>

    {/* Channel Breakdown Bar Chart */}
    <div className="bg-white p-6 rounded-xl shadow-md border">
      <h3 className="text-lg font-semibold mb-4">Follow-ups by Channel</h3>
      <ResponsiveContainer width="100%" height={250}>
        <BarChart data={channelData}>
          <XAxis dataKey="name" />
          <YAxis />
          <Tooltip />
          <Bar dataKey="value" fill="#8884d8" />
        </BarChart>
      </ResponsiveContainer>
    </div>
  </div>
);

export default function CollectionsDashboard() {
  const supabase = createClient();
  const [overdueInvoices, setOverdueInvoices] = useState<any[]>([]);
  const [collectionLogs, setCollectionLogs] = useState<any[]>([]);
  const [loading, setLoading] = useState(true);
  const [stats, setStats] = useState({
    totalOverdue: 0,
    totalAmount: 0,
    paidAfterReminder: 0,
    avgDaysToPay: 0,
    successRate: 0,
  });

  useEffect(() => {
    loadData();
  }, []);

  async function loadData() {
    setLoading(true);
    try {
      // Overdue invoices (30+ days)
      const thirtyDaysAgo = new Date();
      thirtyDaysAgo.setDate(thirtyDaysAgo.getDate() - 30);

      const { data: invoices, error: invErr } = await supabase
        .from('invoices')
        .select(`
          id, amount, due_date, status, reminder_count, last_reminder_sent,
          customer:customers (id, name, phone, email, whatsapp_number)
        `)
        .eq('status', 'pending')
        .lt('due_date', thirtyDaysAgo.toISOString())
        .order('due_date', { ascending: true });

      if (invErr) throw invErr;
      setOverdueInvoices(invoices || []);

      // Collection logs for stats
      const { data: logs } = await supabase
        .from('collection_logs')
        .select('*')
        .order('created_at', { ascending: false });

      setCollectionLogs(logs || []);

      // Calculate stats
      const paid = invoices?.filter(i => i.status === 'paid') || [];
      const total = invoices?.length || 0;
      const successRate = total > 0 ? Math.round((paid.length / total) * 100) : 0;

      let sumDays = 0;
      paid.forEach(inv => {
        if (inv.first_reminder_sent && inv.paid_at) {
          const days = (new Date(inv.paid_at) - new Date(inv.first_reminder_sent)) / (86400000);
          sumDays += days;
        }
      });
      const avgDays = paid.length > 0 ? (sumDays / paid.length).toFixed(1) : '0.0';

      setStats({
        totalOverdue: total,
        totalAmount: invoices?.reduce((sum, i) => sum + i.amount, 0) || 0,
        paidAfterReminder: paid.length,
        avgDaysToPay: avgDays,
        successRate,
      });

    } catch (err: any) {
      toast.error('Failed to load collection data');
      console.error(err);
    } finally {
      setLoading(false);
    }
  }

  async function sendReminder(invoiceId: string, channel: 'whatsapp' | 'email' | 'voice') {
    try {
      const res = await fetch('/api/reminders/send', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ invoiceId, channel }),
      });

      const data = await res.json();

      if (!res.ok) throw new Error(data.error || 'Failed to send reminder');

      toast.success(`Reminder sent via ${channel}`);
      loadData(); // refresh
    } catch (err: any) {
      toast.error(err.message || 'Send failed');
    }
  }

  if (loading) return <div className="p-8 text-center">Loading collections...</div>;

  return (
    <div className="container mx-auto px-4 py-8 max-w-6xl">
      <h1 className="text-3xl font-bold mb-8">Collections & Overdue Invoices</h1>

      {/* Stats Overview */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-6 mb-10">
        <div className="bg-white p-6 rounded-xl shadow-md border">
          <h3 className="text-lg font-semibold text-gray-700">Total Overdue</h3>
          <p className="text-3xl font-bold text-red-600">{stats.totalOverdue}</p>
        </div>
        <div className="bg-white p-6 rounded-xl shadow-md border">
          <h3 className="text-lg font-semibold text-gray-700">Amount Overdue</h3>
          <p className="text-3xl font-bold text-red-600">${stats.totalAmount.toFixed(2)}</p>
        </div>
        <div className="bg-white p-6 rounded-xl shadow-md border">
          <h3 className="text-lg font-semibold text-gray-700">Paid After Reminder</h3>
          <p className="text-3xl font-bold text-green-600">{stats.paidAfterReminder}</p>
        </div>
        <div className="bg-white p-6 rounded-xl shadow-md border">
          <h3 className="text-lg font-semibold text-gray-700">Success Rate</h3>
          <p className="text-3xl font-bold text-purple-600">{stats.successRate}%</p>
          <p className="text-sm text-gray-500">Avg days to pay: {stats.avgDaysToPay}</p>
        </div>
      </div>

      {/* Overdue List */}
      {overdueInvoices.length === 0 ? (
        <div className="bg-gray-100 border rounded-xl p-12 text-center text-gray-600">
          No overdue invoices at the moment.
        </div>
      ) : (
        <div className="overflow-x-auto rounded-xl border border-gray-200 shadow-sm">
          <table className="min-w-full divide-y divide-gray-200">
            <thead className="bg-gray-50">
              <tr>
                <th className="px-6 py-4 text-left text-sm font-medium text-gray-700">Customer</th>
                <th className="px-6 py-4 text-left text-sm font-medium text-gray-700">Invoice ID</th>
                <th className="px-6 py-4 text-left text-sm font-medium text-gray-700">Amount</th>
                <th className="px-6 py-4 text-left text-sm font-medium text-gray-700">Due Date</th>
                <th className="px-6 py-4 text-left text-sm font-medium text-gray-700">Days Overdue</th>
                <th className="px-6 py-4 text-left text-sm font-medium text-gray-700">Last Reminder</th>
                <th className="px-6 py-4 text-left text-sm font-medium text-gray-700">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-gray-200 bg-white">
              {overdueInvoices.map(inv => {
                const daysOverdue = Math.floor((Date.now() - new Date(inv.due_date).getTime()) / 86400000);
                return (
                  <tr key={inv.id} className="hover:bg-gray-50">
                    <td className="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">
                      {inv.customer?.name || 'Unknown'}
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-600">#{inv.id.slice(0, 8)}</td>
                    <td className="px-6 py-4 whitespace-nowrap text-sm font-medium">${inv.amount.toFixed(2)}</td>
                    <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                      {new Date(inv.due_date).toLocaleDateString()}
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap text-sm text-red-600 font-medium">
                      {daysOverdue} days
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                      {inv.last_reminder_sent ? new Date(inv.last_reminder_sent).toLocaleDateString() : 'Never'}
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap text-sm space-x-2">
                      <button
                        onClick={() => sendReminder(inv.id, 'whatsapp')}
                        className="bg-green-600 hover:bg-green-700 text-white px-3 py-1 rounded text-xs"
                      >
                        WhatsApp
                      </button>
                      <button
                        onClick={() => sendReminder(inv.id, 'email')}
                        className="bg-blue-600 hover:bg-blue-700 text-white px-3 py-1 rounded text-xs"
                      >
                        Email
                      </button>
                      <button
                        onClick={() => sendReminder(inv.id, 'voice')}
                        className="bg-purple-600 hover:bg-purple-700 text-white px-3 py-1 rounded text-xs"
                      >
                        Call
                      </button>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      )}

      {/* Collection Success Rate Report */}
      <section className="mt-12">
        <h2 className="text-2xl font-semibold mb-6">Collection Performance</h2>
        <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div className="bg-white p-6 rounded-xl shadow-md border">
            <h3 className="text-lg font-semibold mb-2">Overall Success Rate</h3>
            <p className="text-4xl font-bold text-green-600">{stats.successRate}%</p>
            <p className="text-sm text-gray-500 mt-1">Invoices paid after reminder</p>
          </div>
          <div className="bg-white p-6 rounded-xl shadow-md border">
            <h3 className="text-lg font-semibold mb-2">Avg Days to Pay</h3>
            <p className="text-4xl font-bold text-blue-600">{stats.avgDaysToPay}</p>
            <p className="text-sm text-gray-500 mt-1">After first reminder</p>
          </div>
          <div className="bg-white p-6 rounded-xl shadow-md border">
            <h3 className="text-lg font-semibold mb-2">Total Recovered</h3>
            <p className="text-4xl font-bold text-purple-600">
              ${/* calculate from paid invoices */0}
            </p>
            <p className="text-sm text-gray-500 mt-1">From reminders sent</p>
          </div>
        </div>
      </section>
    </div>
  );
}
